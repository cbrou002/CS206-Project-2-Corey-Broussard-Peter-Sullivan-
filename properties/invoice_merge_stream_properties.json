        "conditions": "left[i] < right[j]",
        "property": "append_left_to_merged",
        "description": "Append element from 'left' to 'merged'."
    },
    {
        "scope": "branch",
        "function": "invoice_merge_stream",
        "conditions": "right[j] < left[i]",
