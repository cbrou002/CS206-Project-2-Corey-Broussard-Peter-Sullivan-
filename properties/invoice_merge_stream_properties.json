        "property": "remove_last_duplicate",
        "description": "Remove last duplicate element when all lists end with the same id."
    },
    {
        "scope": "loop",
        "function": "invoice_merge_stream",
        "property": "iterate_over_lists",
        "description": "Iterate over 'left' and 'right' lists."
